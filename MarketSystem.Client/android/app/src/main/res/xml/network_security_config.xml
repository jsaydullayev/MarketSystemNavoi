<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Production: faqat HTTPS, cleartext yo'q -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>

    <!-- Dev-only cleartext: emulator/localhost backendlar uchun.
         strotech.uz endi HTTPS (Let's Encrypt, 2026-06-04) — apex cleartext
         istisnosi olib tashlandi, shunda prod trafik hech qachon HTTP'ga tushmaydi. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">10.0.3.2</domain>
    </domain-config>
</network-security-config>
