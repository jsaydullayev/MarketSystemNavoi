# =====================================================================
# Root .dockerignore — for the .NET API build context
# =====================================================================

# .NET build outputs
**/bin/
**/obj/
**/out/
**/publish/
**/Debug/
**/Release/
**/x64/
**/x86/
**/Arm/
**/Arm64/
**/bld/
**/Log/
**/Logs/

# Visual Studio
.vs/
.vscode/
*.user
*.suo
*.userosscache
*.sln.docstates

# JetBrains Rider
.idea/

# NuGet
*.nupkg
*.snupkg
packages/
**/packages/

# Test results
TestResults/
*.trx
*.coverage
*.coveragexml
coverlet/

# Flutter (kept out of .NET build context — has its own .dockerignore now)
MarketSystem.Client/

# Git
.git/
.gitignore
.gitattributes

# Documentation (not needed in image)
*.md
README*
CHANGELOG*
LICENSE*
docs/

# Claude / worktrees / scratch
.claude/
.cursor/
.copilot/

# Docker (don't ship docker files inside images)
Dockerfile*
.dockerignore
docker-compose*.yml
docker-compose*.yaml

# Environment & secrets
.env
.env.*
!.env.example
appsettings.Development.json
appsettings.Local.json
secrets.json

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Node (if any frontend ever lands here)
node_modules/
npm-debug.log*
yarn-error.log*

# Python (scripts/)
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Misc
scripts/
update.sql
*.bak
*.tmp
