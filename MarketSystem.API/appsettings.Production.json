{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    // Railway database connection
    // Will be overridden by RAILWAY_DATABASE_URL environment variable
    // Format: postgres://user:password@host:port/database
    "DefaultConnection": "Host=localhost;Port=5432;Database=marketdb;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Key": "PLACEHOLDER_WILL_BE_OVERRIDDEN_BY_RAILWAY_VARIABLES",
    "Issuer": "MarketSystemAPI",
    "Audience": "MarketSystemClient",
    "AccessTokenExpireHours": 14,
    "RefreshTokenDays": 5
  }
}
