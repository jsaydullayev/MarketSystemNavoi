# ========================================
# Deployment Environment Variables
# ========================================
# Copy this file to .env and fill in REAL values.
# Do NOT commit your .env file — it is gitignored.

# Database Connection (Required)
# Use a strong password generated locally, never reuse this example.
# Format: Host=...;Port=5432;Database=MarketSystemDB;Username=postgres;Password=<strong-password>
DATABASE_URL=Host=market-system-db;Port=5432;Database=MarketSystemDB;Username=postgres;Password=REPLACE_ME_WITH_STRONG_PASSWORD

# JWT Configuration (Required)
# Generate a fresh key per environment:
#   openssl rand -base64 48
# MUST be at least 32 characters. Never share between dev and prod.
JWT_KEY=REPLACE_ME_GENERATE_WITH_openssl_rand_base64_48

JWT_ISSUER=MarketSystemAPI
JWT_AUDIENCE=MarketSystemClient

# Docker Postgres credentials (must match DATABASE_URL password)
DB_NAME=MarketSystemDB
DB_USER=postgres
DB_PASSWORD=REPLACE_ME_WITH_STRONG_PASSWORD

# Allowed CORS origins (comma-separated). Example:
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# SuperAdmin console — hidden URL prefix.
# Generated example: openssl rand -hex 16
# The full URL becomes /api/_sa/<this-value>/requests, /api/_sa/<this-value>/owners, ...
# Any other path under /api/_sa/* returns 404 BEFORE auth runs, so a scanner
# can't tell the console exists. Treat this like a password — keep it secret.
SuperAdmin__ConsoleSegment=REPLACE_ME_WITH_openssl_rand_hex_16

# SuperAdmin bootstrap (idempotent, runs on every startup).
# Set on the FIRST deployment, then REMOVE these two vars after the user is
# provisioned. The password is BCrypt-hashed at first login.
SUPERADMIN_USERNAME=
SUPERADMIN_PASSWORD=

# ============================================================================
# Telegram backup pipeline (Variant B: weekly full + daily delta)
#
# See deployment/scripts/TELEGRAM_BACKUP.md for the bot/channel setup,
# the restore procedure, and the design rationale. The two scripts:
#   * backup-db.sh   — Sunday: encrypted pg_dump full · Mon-Sat: CSV delta
#   * send-digest.sh — Sunday: comprehensive Excel · Mon-Sat: daily Excel
# Leave any of the Telegram vars blank to disable that delivery path
# (local copies are still produced and pruned by RETENTION_DAYS).
# ============================================================================

# Bot HTTP API token from @BotFather. The same bot writes to both channels.
TELEGRAM_BOT_TOKEN=

# Private channel for encrypted .dump.gpg / delta.tar.gz.gpg. Negative ID.
# Owners of this channel = your SuperAdmin team. Bot must be admin (post only).
TELEGRAM_RECOVERY_CHAT_ID=

# Private channel for daily/weekly Excel digests. Negative ID. Same bot,
# different channel so business reading doesn't get drowned in encrypted noise.
TELEGRAM_DAILY_CHAT_ID=

# GPG symmetric-encryption passphrase for the .dump.gpg / delta.tar.gz.gpg.
# Generate: openssl rand -hex 32
# ⚠️ Save in a password manager — without this string the backups are useless.
BACKUP_PASSPHRASE=

# Local on-disk retention (days) for the encrypted files. Telegram has its own
# history; this controls /var/backups/marketsystem only.
RETENTION_DAYS=14

# Owner-role login the send-digest.sh script uses to pull Excel reports
# from the API. Make it a dedicated account if you can; .env must be chmod 600.
BACKUP_API_USERNAME=
BACKUP_API_PASSWORD=

# Optional: override the API URL the digest script hits. Default is
# http://localhost:8080/api, which assumes the script runs on the same host
# as the docker-compose stack.
# API_BASE_URL=http://localhost:8080/api

# Optional: language for the Excel digest (uz | ru). Default: uz.
# DIGEST_LANG=uz

# Optional: set to 1 to also gpg-encrypt the digest .xlsx before upload.
# Off by default — Excel files are meant to be opened on the phone unwrapped.
# DIGEST_ENCRYPT=0
