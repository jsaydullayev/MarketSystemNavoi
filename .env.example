# ========================================
# Kamatera Deployment Environment Variables
# ========================================
# Copy this file to .env and fill in your actual values

# Database Connection (Required)
# Format: Host=your-host;Port=5432;Database=MarketSystemDB;Username=your-user;Password=your-password
# Example for external PostgreSQL:
DATABASE_URL=Host=localhost;Port=5432;Database=MarketSystemDB;Username=postgres;Password=your_secure_password

# For Kamatera managed PostgreSQL:
# DATABASE_URL=Host=kamatera-postgres-ip;Port=5432;Database=MarketSystemDB;Username=postgres;Password=your_secure_password

# JWT Configuration (Required)
# Generate a secure key using: openssl rand -base64 32
JWT_KEY=YourSuperSecretKeyThatIsAtLeast32CharactersLongForProductionUse!

JWT_ISSUER=MarketSystemAPI
JWT_AUDIENCE=MarketSystemClient

# Optional: Database credentials (if using docker-compose postgres)
DB_NAME=MarketSystemDB
DB_USER=postgres
DB_PASSWORD=your_secure_password
